{
  "python-envs.pythonProjects": [
    {
      "name": "amc-backend-py",
      "path": "/home/frj/repos/amc-backend-py/.venv/bin/python"
    },
    {
      "path": ".",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ],
  "ruff.lineLength": 120,
  "[python]": {
    "editor.rulers": [120],
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "pycodestyle.args": ["--max-line-length=120"],
  "flake8.args": ["--max-line-length=120"],
  "pylint.args": ["--max-line-length=120"],
  "python.linting.pycodestyleArgs": ["--max-line-length=120"],
  "python.linting.flake8Args": ["--max-line-length=120"],
  "python.linting.pylintArgs": ["--max-line-length=120"],
  "editor.formatOnSave": true
}
