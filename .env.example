APP_ENV=development

# JWT signing secret (min. 32 chars). Generate via: openssl rand -base64 48
JWT_SECRET=replace-me-with-strong-secret-at-least-32-characters
JWT_EXPIRES_IN=3600
JWT_ALGORITHM=HS256

# Comma-separated allowed origins for CORS
CORS_ORIGIN=http://localhost:4200

# SQLAlchemy DATABASE_URL (asyncpg). Alternativ DB_PASSWORD setzen,
# dann wird die URL aus config.json + DB_PASSWORD aufgebaut.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5436/amcadmin
# DB_PASSWORD=

# SMTP passwords per signature key (matches config.json signature names, upper-case)
SMTP_PWD_JANINEFRANKEN=
SMTP_PWD_HANSJOERGDUTLER=
